# ================================
# SHOPIFY (OAuth App)
# ================================
# Partner Dashboard -> Tu App -> Client credentials
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================
# MERCADO PAGO
# ================================
# Los merchants conectan su propia cuenta de MP via OAuth desde el admin panel.
# Estas credenciales son de TU app de MP (no del merchant):
# mercadopago.com.ar/developers -> Tu App -> Credenciales
MP_CLIENT_ID=0000000000000000
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Clave secreta para verificar webhooks (la definís vos, cualquier string largo)
MP_WEBHOOK_SECRET=mi_clave_secreta_webhooks_123

# ================================
# BASE DE DATOS
# ================================
# Local: postgresql://postgres:password@localhost:5432/suscripciones
# Railway: te lo dan cuando creás la base de datos
DATABASE_URL=postgresql://postgres:password@localhost:5432/suscripciones

# ================================
# APP
# ================================
PORT=3000
# URL pública de tu app (ngrok local o Railway en producción)
APP_URL=https://tu-app.up.railway.app
# Cualquier string largo y aleatorio para sesiones (mínimo 32 chars)
SESSION_SECRET=cambia_esto_por_algo_largo_y_aleatorio_123456
# Clave de encriptación para tokens guardados en la DB (Shopify, MP, Klaviyo)
# Generá una nueva con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: si la perdés, los tokens guardados se vuelven irrecuperables
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nombre de tu tienda (aparece en el email de confirmación)
STORE_NAME=Mi Tienda

# ================================
# ADMIN LOGIN
# ================================
# Usuario y contraseña para entrar al panel /admin
# Cambiá estos valores antes de ir a producción
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contrasena_segura_123

# ================================
# EMAIL (SMTP)
# ================================
# Gmail: host=smtp.gmail.com, port=587, secure=false
# Usá una "contraseña de aplicación" de Google (no tu contraseña normal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tuemail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
