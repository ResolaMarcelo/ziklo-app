generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuarios del panel admin (merchants + superadmins)
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    // null si solo usa Google
  googleId     String?    @unique
  name         String?
  role                 String     @default("merchant") // "merchant" | "superadmin"
  emailVerified        Boolean    @default(false)
  verificationCode     String?
  verificationExpiry   DateTime?
  resetToken           String?    @unique
  resetTokenExpiry     DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  shops                UserShop[]
}

// Relación muchos-a-muchos entre User y Shop
model UserShop {
  userId     String
  shopDomain String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop       Shop   @relation(fields: [shopDomain], references: [domain], onDelete: Cascade)

  @@id([userId, shopDomain])
}

// Tiendas Shopify autenticadas via OAuth
model Shop {
  id            String         @id @default(cuid())
  domain        String         @unique  // ej: mi-tienda.myshopify.com
  accessToken   String                  // token de Shopify Admin API
  mpAccessToken   String?                 // token de Mercado Pago de esta tienda
  shopName        String?                 // nombre de la tienda (cacheado)
  email           String?                 // email del owner
  subBenefitType  String?                 // "discount" | "gift" | "free_shipping"
  subBenefitValue String?                 // "10" | "Muestra de crema"
  widgetTitle     String?                 // Titular del tab de suscripción en el widget
  widgetChips     String?                 // JSON array de chips (["📦 Entrega mensual", ...])
  widgetBtnText   String?                 // Texto del botón ATC en modo suscripción
  // Retención
  // Klaviyo OAuth
  klaviyoAccessToken  String?
  klaviyoRefreshToken String?
  klaviyoTokenExpiry  DateTime?
  // Retención
  retentionPauseEnabled    Boolean @default(false)
  retentionDiscountEnabled Boolean @default(false)
  retentionDiscountPct     Int?
  retentionSurveyEnabled   Boolean @default(false)
  retentionMessage         String?
  installedAt   DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         UserShop[]
  plans         Plan[]
  subscriptions Subscription[]
}

model Plan {
  id             String         @id @default(cuid())
  shopDomain     String                 // tienda a la que pertenece este plan
  shop           Shop           @relation(fields: [shopDomain], references: [domain])
  nombre         String
  descripcion    String?
  monto          Float
  frecuencia     Int            @default(1)
  tipoFrecuencia String         @default("months") // "months" | "days"
  activo         Boolean        @default(true)
  beneficios     String?        // JSON array de strings con los beneficios del plan
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]

  @@index([shopDomain])
}

model Subscription {
  id                   String   @id @default(cuid())
  shopDomain           String            // tienda a la que pertenece
  shop                 Shop     @relation(fields: [shopDomain], references: [domain])
  shopifyCustomerId    String
  shopifyCustomerEmail String
  variantId            String?
  productId            String?
  mpPreapprovalId      String   @unique
  status               String   @default("pending") // pending | authorized | paused | cancelled
  plan                 Plan     @relation(fields: [planId], references: [id])
  planId               String
  datosEnvio           String?  // JSON: nombre, apellido, telefono, direccion, ciudad, provincia, cp
  qty                  Int?     @default(1)
  retentionDiscountApplied Boolean @default(false)
  nextChargeDate       DateTime?               // fecha estimada del próximo cobro (actualizada por webhook)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  pagos                Pago[]
  cancelReasons        CancelReason[]

  @@index([shopDomain])
}

model Pago {
  id             String       @id @default(cuid())
  mpPaymentId    String       @unique
  monto          Float
  status         String       // approved | rejected | pending
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
  createdAt      DateTime     @default(now())
}

// Token de un solo uso para autenticar el portal /cliente via magic link
model MagicToken {
  id         String    @id @default(cuid())
  email      String
  shopDomain String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, shopDomain])
}

model CancelReason {
  id             String       @id @default(cuid())
  subscriptionId String
  reason         String
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// Productos de Shopify con suscripciones activadas por el merchant
model ProductSubscription {
  id           String   @id @default(cuid())
  shopDomain   String
  productId    String
  productTitle String?
  productImage String?
  enabled      Boolean  @default(true)
  benefitType  String?  // null = heredar global del shop
  benefitValue String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shopDomain, productId])
  @@index([shopDomain])
}
