generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuarios del panel admin (merchants + superadmins)
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    // null si solo usa Google
  googleId     String?    @unique
  name         String?
  role                 String     @default("merchant") // "merchant" | "superadmin"
  emailVerified        Boolean    @default(false)
  verificationCode     String?
  verificationExpiry   DateTime?
  resetToken           String?    @unique
  resetTokenExpiry     DateTime?
  failedLoginAttempts  Int        @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  shops                UserShop[]
}

// Relación muchos-a-muchos entre User y Shop
model UserShop {
  userId     String
  shopDomain String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop       Shop   @relation(fields: [shopDomain], references: [domain], onDelete: Cascade)

  @@id([userId, shopDomain])
}

// Tiendas autenticadas via OAuth (Shopify o Tiendanube)
model Shop {
  id            String         @id @default(cuid())
  domain        String         @unique  // ej: mi-tienda.myshopify.com o mi-tienda.mitiendanube.com
  platform      String         @default("shopify") // "shopify" | "tiendanube"
  accessToken   String?                 // token de la plataforma (Shopify o Tiendanube, encriptado)
  tiendanubeStoreId String?    @unique  // ID numérico de la tienda en Tiendanube
  mpAccessToken   String?                 // token de Mercado Pago de esta tienda
  shopName        String?                 // nombre de la tienda (cacheado)
  email           String?                 // email del owner
  subBenefitType  String?                 // "discount" | "gift" | "free_shipping"
  subBenefitValue String?                 // "10" | "Muestra de crema"
  widgetTitle     String?                 // Titular del tab de suscripción en el widget
  widgetChips     String?                 // JSON array de chips (["📦 Entrega mensual", ...])
  widgetBtnText     String?                 // Texto del botón ATC en modo suscripción
  widgetChipsVisible Boolean @default(true)  // Mostrar/ocultar chips de beneficios en el widget
  widgetAccentColor String?                 // Color de acento del widget (hex, ej: #222222)
  widgetBgColor     String?                 // Color de fondo del widget (hex, ej: #fafafa)
  widgetTextColor   String?                 // Color de texto del widget (hex, ej: #111111)
  // Klaviyo OAuth
  klaviyoAccessToken  String?
  klaviyoRefreshToken String?
  klaviyoTokenExpiry  DateTime?
  // Retención
  retentionPauseEnabled    Boolean @default(false)
  retentionDiscountEnabled Boolean @default(false)
  retentionDiscountPct     Int?
  retentionSurveyEnabled   Boolean @default(false)
  retentionMessage         String?
  // Billing Ziklo
  billingPlan       String   @default("free")  // "free" | "starter" | "growth" | "pro" | "enterprise"
  monthlyCharges    Int      @default(0)        // cobros exitosos en el mes corriente
  chargesResetAt    DateTime?                   // cuándo se reseteó el contador por última vez
  installedAt   DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         UserShop[]
  plans         Plan[]
  subscriptions Subscription[]
}

model Plan {
  id             String         @id @default(cuid())
  shopDomain     String                 // tienda a la que pertenece este plan
  shop           Shop           @relation(fields: [shopDomain], references: [domain])
  nombre         String
  descripcion    String?
  monto          Float
  frecuencia     Int            @default(1)
  tipoFrecuencia String         @default("months") // "months" | "days"
  activo         Boolean        @default(true)
  beneficios     String?        // JSON array de strings con los beneficios del plan
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]

  @@index([shopDomain])
}

model Subscription {
  id                   String   @id @default(cuid())
  shopDomain           String            // tienda a la que pertenece
  shop                 Shop     @relation(fields: [shopDomain], references: [domain])
  shopifyCustomerId    String
  shopifyCustomerEmail String
  variantId            String?
  productId            String?
  mpPreapprovalId      String   @unique
  status               String   @default("pending") // pending | authorized | paused | cancelled
  plan                 Plan     @relation(fields: [planId], references: [id])
  planId               String
  datosEnvio           String?  // JSON: nombre, apellido, telefono, direccion, ciudad, provincia, cp
  qty                  Int?     @default(1)
  retentionDiscountApplied Boolean @default(false)
  pendingUpsells       String?                 // JSON: [{ productId, variantId, title, price, qty }]
  nextChargeDate       DateTime?               // fecha estimada del próximo cobro (actualizada por webhook)
  lastReminderSentAt   DateTime?               // última vez que se envió recordatorio de cobro (evita duplicados)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  pagos                Pago[]
  cancelReasons        CancelReason[]

  @@index([shopDomain])
}

model Pago {
  id                  String       @id @default(cuid())
  mpPaymentId         String       @unique
  monto               Float
  status              String       // approved | rejected | pending
  shopifyOrderId      String?      // ID interno de la orden Shopify
  shopifyOrderNumber  Int?         // Nro de orden legible (#1001, #1002...)
  subscription        Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId      String
  createdAt           DateTime     @default(now())
}

// Token de un solo uso para autenticar el portal /cliente via magic link
model MagicToken {
  id         String    @id @default(cuid())
  email      String
  shopDomain String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, shopDomain])
}

model CancelReason {
  id             String       @id @default(cuid())
  subscriptionId String
  reason         String
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// Lista de espera para acceso beta
model WaitlistEntry {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  tienda    String?  // URL de su tienda Shopify (opcional)
  mensaje   String?  // mensaje libre del solicitante
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Productos de Shopify con suscripciones activadas por el merchant
model ProductSubscription {
  id           String   @id @default(cuid())
  shopDomain   String
  productId    String
  productTitle String?
  productImage String?
  enabled      Boolean  @default(true)
  benefitType  String?  // null = heredar global del shop
  benefitValue String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shopDomain, productId])
  @@index([shopDomain])
}

// Recomendaciones de productos (upsell/cross-sell configuradas por el merchant)
model ProductRecommendation {
  id              String   @id @default(cuid())
  shopDomain      String
  sourceProductId String   // producto con suscripción
  targetProductId String   // producto recomendado
  targetTitle     String?
  targetImage     String?
  targetPrice     Float?
  targetVariantId String?  // para agregar al order de Shopify
  position        Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([shopDomain, sourceProductId, targetProductId])
  @@index([shopDomain, sourceProductId])
}

// Log de acciones de admin para auditoría
model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  userId     String?
  shopDomain String?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([shopDomain])
}
