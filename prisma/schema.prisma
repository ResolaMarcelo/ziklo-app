generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id            String         @id @default(cuid())
  nombre        String
  descripcion   String?
  monto         Float
  frecuencia    Int            @default(1)
  tipoFrecuencia String        @default("months") // "months" | "days"
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                  String   @id @default(cuid())
  shopifyCustomerId   String
  shopifyCustomerEmail String
  variantId           String?
  productId           String?
  mpPreapprovalId     String   @unique
  status              String   @default("pending") // pending | authorized | paused | cancelled
  plan                Plan     @relation(fields: [planId], references: [id])
  planId              String
  datosEnvio          String?  // JSON: nombre, apellido, telefono, direccion, ciudad, provincia, cp
  qty                 Int?     @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  pagos               Pago[]
}

model Pago {
  id             String       @id @default(cuid())
  mpPaymentId    String       @unique
  monto          Float
  status         String       // approved | rejected | pending
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
  createdAt      DateTime     @default(now())
}
